workspace 'THLHOSTS'

def common_pods
  use_frameworks!
  pod 'Masonry'
  pod 'Swifter', :git => 'https://github.com/yichengchen/swifter'
  pod 'SnapKit'
end

target 'THLHOSTSApp' do
  platform :ios, '14.0'
  project 'THLHOSTSApp/THLHOSTSApp.xcodeproj'
  common_pods
end

